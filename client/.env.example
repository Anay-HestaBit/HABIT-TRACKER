# ─────────────────────────────────────────────────────────────────
#  CLIENT ENVIRONMENT VARIABLES
#  For LOCAL development: do NOT create a .env file here.
#  The vite.config.js proxy routes /api/* → localhost:5000 automatically,
#  so VITE_API_URL is not needed locally.
#
#  For PRODUCTION: set VITE_API_URL in the Vercel project dashboard.
#  Do NOT commit a .env or .env.production file.
# ─────────────────────────────────────────────────────────────────

# Only used in production — set in Vercel dashboard, not here:
# VITE_API_URL=https://habit-tracker-api.onrender.com/api
