# ─────────────────────────────────────────────────────────────────
#  SERVER ENVIRONMENT VARIABLES
#  Copy this to .env and fill in real values.
#  NEVER commit your actual .env file — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────

# =================================================================
# 1) LOCAL DEV (manual terminals)
# =================================================================
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/habitjourney
REDIS_URL=redis://127.0.0.1:6379
CLIENT_URL=http://localhost:5173

# Secrets and external services (same keys for all environments)
# JWT Secret — must be a long random string (at least 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING

# SMTP — Gmail App Password (NOT your real Gmail password)
# Setup: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
FROM_EMAIL=your_gmail@gmail.com
FROM_NAME=Daily Habit Journey

# Cloudinary (for profile picture uploads)
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin panel token — protects /admin/queues
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_SECRET=REPLACE_WITH_RANDOM_STRING

# =================================================================
# 2) LOCAL DOCKER COMPOSE
# =================================================================
# NODE_ENV=production
# PORT=5000
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# REDIS_URL=redis://redis:6379
# CLIENT_URL=http://localhost:8080

# (Use the same JWT_SECRET, SMTP_*, CLOUDINARY_*, ADMIN_SECRET values as above)

# =================================================================
# 3) PRODUCTION (Render backend + Vercel frontend)
# =================================================================
# NODE_ENV=production
# PORT=10000
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
# CLIENT_URL=https://your-app.vercel.app

# (Use the same JWT_SECRET, SMTP_*, CLOUDINARY_*, ADMIN_SECRET values as above)
